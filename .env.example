# API Keys for AI Server
# Copy this file to .env and fill in your keys
# .env is in .gitignore - will NEVER be committed

# Groq API Key (free: https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini API Key (free: https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# Optional: API key for server-to-client auth (to block public abuse)
# If empty, no auth required
API_KEY=
