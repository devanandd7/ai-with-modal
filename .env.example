# ═══════════════════════════════════════════════════════════════
#  AI Server — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#  📌 Copy this file to .env and fill in your keys:
#     copy .env.example .env
#
#  🔒 .env is in .gitignore → NEVER committed to Git
#  🔐 Keys only live inside Modal Server (encrypted env vars)
# ═══════════════════════════════════════════════════════════════


# ─── API KEYS ──────────────────────────────────────────────────

# Groq API Key — Free tier: ~30 req/min | https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gemini API Key — Free tier: 60 req/min | https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# Optional: Server Auth Key (har request me X-API-Key header chahiye hoga)
# Empty rakhoge to koi bhi use kar sakta hai (public)
API_KEY=


# ─── MODEL CONFIGURATION ──────────────────────────────────────
#  Change these to switch model versions without changing code
# ──────────────────────────────────────────────────────────────

# Groq models: https://console.groq.com/docs/models
#   llama-3.3-70b-versatile   → best quality (slow)
#   llama-3.1-70b-versatile   → good balance (default)
#   llama-3.1-8b-instant      → fastest (lower quality)
#   mixtral-8x7b-32768        → Mixtral MoE
#   gemma2-9b-it              → Google Gemma 2
GROQ_MODEL=llama-3.1-70b-versatile

# Gemini models: https://ai.google.dev/gemini-api/docs/models
#   gemini-2.0-flash          → fastest, good quality (default)
#   gemini-2.0-flash-lite     → even faster, slightly lower quality
#   gemini-1.5-flash          → stable, older version
#   gemini-1.5-pro            → best quality (slower, higher quota cost)
GEMINI_MODEL=gemini-2.0-flash

# Qwen (self-hosted on Modal GPU — no API key needed)
# Change MODEL_ID to use a different HuggingFace model
# Examples:
#   Qwen/Qwen2.5-7B-Instruct          → default
#   Qwen/Qwen2.5-7B-Instruct-1M       → 1M context window
#   mistralai/Mistral-7B-Instruct-v0.3 → Mistral 7B
#   microsoft/Phi-3-mini-4k-instruct   → Phi-3 (smaller, faster)
#   meta-llama/Llama-3.2-3B-Instruct  → Llama 3.2 3B (lighter)
QWEN_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
